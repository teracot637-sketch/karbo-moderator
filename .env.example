# токен бота, без него никуда
KARBO_BOT_TOKEN=your_bot_token_here

# мой uuid, чтобы /leave можно было дёрнуть из любого чата
BOT_OWNER_ID=

# база
DB_PATH=moderator.db

# дефолтный лимит варнов в новом чате
DEFAULT_WARN_LIMIT=10

# nsfw авто-модерация
NSFW_ENABLED=1
NSFW_THRESHOLD=0.6
NSFW_WARN_LIMIT=3

# роли (1 = помощник, 2 = организатор - так в karbo)
HELPER_ROLE_MIN=1
ORGANIZER_ROLE_MIN=2

# на сколько секунд кэшим роль самого бота
BOT_ROLE_TTL=300

CMD_PREFIX=/
LOG_LEVEL=INFO
